import pandas as pd

df = pd.read_excel('/content/Online-Store-Orders.xlsx')


print("Dataset Shape:", df.shape)
print("\nColumns:")
print(df.columns)

print("\nFirst 5 Rows:")
print(df.head())


print("\nMissing Values:")
print(df.isnull().sum())


df['CouponCode'] = df['CouponCode'].fillna('No Coupon')


duplicates = df.duplicated().sum()
print("\nDuplicate Records:", duplicates)


df = df.drop_duplicates()


print("\nData Types:")
print(df.dtypes)


df['Date'] = pd.to_datetime(df['Date'])




invalid_quantity = df[df['Quantity'] <= 0]


invalid_price = df[df['UnitPrice'] <= 0]


invalid_total = df[df['TotalPrice'] <= 0]

print("\nInvalid Quantity Records:", len(invalid_quantity))
print("Invalid UnitPrice Records:", len(invalid_price))
print("Invalid TotalPrice Records:", len(invalid_total))


df['Calculated_Total'] = df['Quantity'] * df['UnitPrice']

mismatch = df[
    abs(df['Calculated_Total'] - df['TotalPrice']) > 0.01
]

print("\nTotalPrice Mismatches:", len(mismatch))


df.drop('Calculated_Total', axis=1, inplace=True)


print("\nCleaned Dataset Shape:", df.shape)
df.to_excel('Cleaned_Online_Store_Orders.xlsx', index=False)

print("\nData Cleaning Completed Successfully!")
print("Cleaned file saved as: Cleaned_Online_Store_Orders.xlsx")